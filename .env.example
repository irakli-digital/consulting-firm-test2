# Required: n8n webhook URL for form submissions
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/geopermit-lead

# Required: Public site URL for SEO and metadata
NEXT_PUBLIC_SITE_URL=https://geopermit.ge

# Optional: Webhook authentication secret (must match n8n Header Auth config)
N8N_WEBHOOK_SECRET=your-webhook-secret-here
